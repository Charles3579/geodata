          "geosite:icloudprivaterelay",
          "geosite:bing",
          "geosite:netflix",
          "geosite:disney",
          "geosite:primevideo",
          "geosite:hbo",
          "geosite:hulu",
          "geosite:dazn",
          "geosite:hotstar",
          "geosite:tvb",
          "geosite:viu",
          "geosite:spotify",
          "geosite:tiktok",
          "geosite:apple",
